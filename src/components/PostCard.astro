---
const CAT_LABELS: Record<string, string> = {
  sns:   '유튜브·SNS',
  ai:    'AI·신기술',
  신조어: '신조어·뜻',
  생활:  '생활·상식',
  it:    'IT·컴퓨터',
  엔터:  '엔터·이슈',
};
const CAT_COLORS: Record<string, string> = {
  sns:   'badge-sns',
  ai:    'badge-ai',
  신조어: 'badge-word',
  생활:  'badge-life',
  it:    'badge-it',
  엔터:  'badge-ent',
};
// Phosphor Icons regular weight — ph ph-{name}
const CAT_ICONS: Record<string, string> = {
  sns:   'ph-youtube-logo',
  ai:    'ph-robot',
  신조어: 'ph-chat-circle-text',
  생활:  'ph-house-simple',
  it:    'ph-laptop',
  엔터:  'ph-film-strip',
};
const CAT_BG: Record<string, string> = {
  sns:   'thumb-sns',
  ai:    'thumb-ai',
  신조어: 'thumb-word',
  생활:  'thumb-life',
  it:    'thumb-it',
  엔터:  'thumb-ent',
};

interface Props {
  slug: string;
  title: string;
  description?: string;
  pubDate?: Date;
  category?: string;
  thumbnail?: string;
}

const { slug, title, description, pubDate, category, thumbnail } = Astro.props;
const dateStr = pubDate
  ? pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' })
  : null;
const catLabel  = category ? CAT_LABELS[category] : null;
const catColor  = category ? CAT_COLORS[category] : 'badge-ent';
const catIcon   = category ? (CAT_ICONS[category] ?? 'ph-newspaper') : 'ph-newspaper';
const catBg     = category ? (CAT_BG[category]    ?? 'thumb-ent')    : 'thumb-ent';
---

<li class="post-card">
  <a href={`/entry/${slug}`} class="post-card-link">
    <!--
      항상 카테고리 아이콘을 배경에 렌더링.
      thumbnail이 있으면 img가 위에서 덮음.
      img가 404면 onerror로 img만 숨기고 아이콘 노출.
    -->
    <div class:list={['post-card-thumb', catBg]}>
      <i class:list={['ph', catIcon, 'thumb-icon']} aria-hidden="true"></i>
      {thumbnail && (
        <img
          src={thumbnail}
          alt={`${title} 썸네일`}
          class="thumb-img"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'"
        />
      )}
    </div>

    <article class="post-card-body">
      <div class="post-card-meta">
        {catLabel && <span class={`badge ${catColor}`}>{catLabel}</span>}
        {dateStr && <time class="post-card-date">{dateStr}</time>}
      </div>
      <h2 class="post-card-title">{title}</h2>
      {description && <p class="post-card-desc">{description}</p>}
    </article>
  </a>
</li>

<style>
  .post-card-link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    text-decoration: none;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    transition: box-shadow var(--transition-fast), border-color var(--transition-fast);
    background: var(--color-bg);
  }
  .post-card-link:hover {
    border-color: var(--color-primary-light);
    box-shadow: var(--shadow-md);
  }

  /* ── 썸네일 래퍼 ── */
  .post-card-thumb {
    position: relative;
    flex-shrink: 0;
    width: 160px;
    height: 120px;
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* 카테고리별 배경색 */
  .thumb-sns  { background: #EFF6FF; color: #1D4ED8; }
  .thumb-ai   { background: #F0FDF4; color: #15803D; }
  .thumb-word { background: #FFF7ED; color: #C2410C; }
  .thumb-life { background: #FDF4FF; color: #7E22CE; }
  .thumb-it   { background: #F0F9FF; color: #0369A1; }
  .thumb-ent  { background: #FFF1F2; color: #BE123C; }

  /* 카테고리 아이콘 (배경 레이어) */
  .thumb-icon {
    font-size: 2.25rem;
    opacity: 0.85;
  }

  /* 실제 이미지 (아이콘 위 절대 레이어 — 로드 성공 시 덮음) */
  .thumb-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 본문 */
  .post-card-body { flex: 1; min-width: 0; }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
    flex-wrap: wrap;
  }

  .post-card-title {
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    margin: 0 0 var(--space-1);
    word-break: keep-all;
    overflow-wrap: break-word;
    transition: color var(--transition-fast);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.45;
  }
  .post-card-link:hover .post-card-title { color: var(--color-primary); }

  .post-card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-date {
    font-size: var(--text-xs);
    color: var(--color-text-light);
  }

  /* 뱃지 */
  .badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: var(--font-weight-semibold);
    padding: 2px 7px;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }
  .badge-sns  { background: #EFF6FF; color: #1D4ED8; }
  .badge-ai   { background: #F0FDF4; color: #15803D; }
  .badge-word { background: #FFF7ED; color: #C2410C; }
  .badge-life { background: #FDF4FF; color: #7E22CE; }
  .badge-it   { background: #F0F9FF; color: #0369A1; }
  .badge-ent  { background: #FFF1F2; color: #BE123C; }

  /* 태블릿 */
  @media (max-width: 640px) {
    .post-card-thumb { width: 120px; height: 90px; }
    .thumb-icon { font-size: 1.75rem; }
    .post-card-desc { display: none; }
  }

  /* 소형 모바일 */
  @media (max-width: 380px) {
    .post-card-link { gap: var(--space-3); padding: var(--space-3); }
    .post-card-thumb { width: 96px; height: 72px; }
    .thumb-icon { font-size: 1.5rem; }
    .post-card-title { font-size: var(--text-sm); }
  }
</style>
