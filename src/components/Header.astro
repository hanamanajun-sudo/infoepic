---
---

<header class="site-header">
  <div class="container--wide header-inner">
    <a href="/" class="logo" aria-label="infoepic 홈">
      <span class="logo-text">info<span class="logo-accent">epic</span></span>
    </a>

    <!-- 데스크탑 네비 -->
    <nav class="site-nav desktop-nav" aria-label="메인 메뉴">
      <a href="/">홈</a>
      <a href="/category/it">IT·컴퓨터</a>
      <a href="/category/sns">유튜브·SNS</a>
      <a href="/category/ai">AI·신기술</a>
      <a href="/category/신조어">신조어·뜻</a>
      <a href="/category/생활">생활·상식</a>
      <a href="/category/엔터">엔터·이슈</a>
      <a href="/about" class="nav-about">소개</a>
    </nav>

    <!-- 검색 -->
    <button class="search-btn" id="header-search-btn" aria-label="검색">
      <i class="ph ph-magnifying-glass" aria-hidden="true"></i>
    </button>

    <!-- 모바일 햄버거 -->
    <button class="hamburger" id="hamburger" aria-label="메뉴 열기" aria-expanded="false" aria-controls="mobile-nav">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>
</header>

<!-- 모바일 드로어 -->
<div class="mobile-nav-overlay" id="mobile-overlay" aria-hidden="true"></div>
<nav class="mobile-nav" id="mobile-nav" aria-label="모바일 메뉴" aria-hidden="true">
  <div class="mobile-nav-header">
    <span class="mobile-nav-title">메뉴</span>
    <button class="mobile-nav-close" id="nav-close" aria-label="메뉴 닫기">
      <i class="ph ph-x" aria-hidden="true"></i>
    </button>
  </div>
  <ul class="mobile-nav-list">
    <li><a href="/">🏠 홈 (전체)</a></li>
    <li class="nav-section">카테고리</li>
    <li><a href="/category/it">💻 IT·컴퓨터</a></li>
    <li><a href="/category/sns">▶️ 유튜브·SNS</a></li>
    <li><a href="/category/ai">🤖 AI·신기술</a></li>
    <li><a href="/category/신조어">💬 신조어·뜻</a></li>
    <li><a href="/category/생활">🏡 생활·상식</a></li>
    <li><a href="/category/엔터">🎬 엔터·이슈</a></li>
    <li class="nav-divider"></li>
    <li><a href="/about">소개</a></li>
    <li><a href="/contact">문의</a></li>
  </ul>
</nav>

<script>
  const hamburger = document.getElementById('hamburger')!;
  const mobileNav = document.getElementById('mobile-nav')!;
  const overlay = document.getElementById('mobile-overlay')!;
  const closeBtn = document.getElementById('nav-close')!;

  function openNav() {
    mobileNav.classList.add('open');
    overlay.classList.add('open');
    hamburger.setAttribute('aria-expanded', 'true');
    mobileNav.setAttribute('aria-hidden', 'false');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeNav() {
    mobileNav.classList.remove('open');
    overlay.classList.remove('open');
    hamburger.setAttribute('aria-expanded', 'false');
    mobileNav.setAttribute('aria-hidden', 'true');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  hamburger.addEventListener('click', openNav);
  closeBtn.addEventListener('click', closeNav);

  // 검색 버튼 → 검색 모달 오픈
  document.getElementById('header-search-btn')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-search'));
  });
  overlay.addEventListener('click', closeNav);
  mobileNav.querySelectorAll('a').forEach(a => a.addEventListener('click', closeNav));
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 200;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    gap: var(--space-4);
  }

  .logo {
    text-decoration: none;
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }
  .logo-text { color: var(--color-text); }
  .logo-accent { color: var(--color-primary); }

  /* ── 데스크탑 nav ── */
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    flex: 1;
    justify-content: flex-end;
  }
  .desktop-nav a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: var(--font-weight-medium);
    padding: 5px 9px;
    border-radius: var(--radius-md);
    white-space: nowrap;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .desktop-nav a:hover {
    background: var(--color-bg-subtle);
    color: var(--color-text);
  }
  .desktop-nav .nav-about {
    margin-left: var(--space-2);
    border: 1px solid var(--color-border);
  }

  /* ── 검색 버튼 ── */
  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 1.1rem;
    flex-shrink: 0;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .search-btn:hover {
    background: var(--color-bg-subtle);
    color: var(--color-text);
  }

  /* ── 햄버거 ── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: var(--radius-md);
  }
  .hamburger:hover { background: var(--color-bg-subtle); }
  .bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition-fast);
  }

  /* ── 모바일 오버레이 ── */
  .mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 299;
  }
  .mobile-nav-overlay.open { display: block; }

  /* ── 모바일 드로어 ── */
  .mobile-nav {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(280px, 85vw);
    background: var(--color-bg);
    box-shadow: var(--shadow-lg);
    z-index: 300;
    transform: translateX(100%);
    transition: transform 250ms ease;
    overflow-y: auto;
  }
  .mobile-nav.open { transform: translateX(0); }

  .mobile-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }
  .mobile-nav-title {
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
  }
  .mobile-nav-close {
    width: 32px;
    height: 32px;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: var(--radius-md);
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }
  .mobile-nav-close:hover { background: var(--color-bg-subtle); }

  .mobile-nav-list {
    list-style: none;
    padding: var(--space-3) 0;
    margin: 0;
  }
  .mobile-nav-list a {
    display: block;
    padding: 11px var(--space-5);
    text-decoration: none;
    font-size: var(--text-sm);
    color: var(--color-text);
    transition: background var(--transition-fast);
  }
  .mobile-nav-list a:hover { background: var(--color-bg-subtle); }

  .nav-section {
    padding: var(--space-3) var(--space-5) var(--space-1);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .nav-divider {
    height: 1px;
    background: var(--color-border);
    margin: var(--space-2) var(--space-5);
  }

  /* ── 반응형: 860px 이하 햄버거로 전환 ── */
  @media (max-width: 860px) {
    .desktop-nav { display: none; }
    .hamburger { display: flex; }
  }

  /* 데스크탑: 햄버거 숨김, 검색 버튼 항상 표시 */
  @media (min-width: 861px) {
    .hamburger { display: none; }
  }
</style>
